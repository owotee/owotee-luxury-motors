{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://3.137.207.41/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://3.137.207.41/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
